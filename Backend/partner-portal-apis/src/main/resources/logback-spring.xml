<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <springProperty scope="context" name="LOG_PATH" source="app.logging.dir" />

    Console appender
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{tenantId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ====== DEV and SIT Environments ====== -->
    <springProfile name="dev | sit">

        <!-- INFO logs per tenant -->
        <appender name="TENANT_INFO_APPENDER" class="ch.qos.logback.classic.sift.SiftingAppender">
            <discriminator class="ch.qos.logback.classic.sift.MDCBasedDiscriminator">
                <key>tenantId</key>
                <defaultValue>default</defaultValue>
            </discriminator>
            <sift>
                <appender name="INFO-FILE-${tenantId}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                    <file>${LOG_PATH}/${tenantId}/partnerportal_Info.log</file>
                    <filter class="ch.qos.logback.classic.filter.LevelFilter">
                        <level>INFO</level>
                        <onMatch>ACCEPT</onMatch>
                        <onMismatch>DENY</onMismatch>
                    </filter>
                    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                        <fileNamePattern>${LOG_PATH}/${tenantId}/archived/info-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                        <maxFileSize>10MB</maxFileSize>
                        <maxHistory>30</maxHistory>
                    </rollingPolicy>
                    <encoder>
                        <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{tenantId}] - %msg%n</pattern>
                    </encoder>
                </appender>
            </sift>
        </appender>

        <!-- DEBUG logs per tenant -->
        <appender name="TENANT_DEBUG_APPENDER" class="ch.qos.logback.classic.sift.SiftingAppender">
            <discriminator class="ch.qos.logback.classic.sift.MDCBasedDiscriminator">
                <key>tenantId</key>
                <defaultValue>default</defaultValue>
            </discriminator>
            <sift>
                <appender name="DEBUG-FILE-${tenantId}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                    <file>${LOG_PATH}/${tenantId}/partnerportal_Debug.log</file>
                    <filter class="ch.qos.logback.classic.filter.LevelFilter">
                        <level>DEBUG</level>
                        <onMatch>ACCEPT</onMatch>
                        <onMismatch>DENY</onMismatch>
                    </filter>
                    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                        <fileNamePattern>${LOG_PATH}/${tenantId}/archived/debug-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                        <maxFileSize>10MB</maxFileSize>
                        <maxHistory>30</maxHistory>
                    </rollingPolicy>
                    <encoder>
                        <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{tenantId}] - %msg%n</pattern>
                    </encoder>
                </appender>
            </sift>
        </appender>

        <!-- ERROR logs per tenant -->
        <appender name="TENANT_ERROR_APPENDER" class="ch.qos.logback.classic.sift.SiftingAppender">
            <discriminator class="ch.qos.logback.classic.sift.MDCBasedDiscriminator">
                <key>tenantId</key>
                <defaultValue>default</defaultValue>
            </discriminator>
            <sift>
                <appender name="ERROR-FILE-${tenantId}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                    <file>${LOG_PATH}/${tenantId}/partnerportal_Error.log</file>
                    <filter class="ch.qos.logback.classic.filter.LevelFilter">
                        <level>ERROR</level>
                        <onMatch>ACCEPT</onMatch>
                        <onMismatch>DENY</onMismatch>
                    </filter>
                    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                        <fileNamePattern>${LOG_PATH}/${tenantId}/archived/error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                        <maxFileSize>10MB</maxFileSize>
                        <maxHistory>30</maxHistory>
                    </rollingPolicy>
                    <encoder>
                        <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{tenantId}] - %msg%n</pattern>
                    </encoder>
                </appender>
            </sift>
        </appender>

        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="TENANT_INFO_APPENDER"/>
            <appender-ref ref="TENANT_DEBUG_APPENDER"/>
            <appender-ref ref="TENANT_ERROR_APPENDER"/>
        </root>
    </springProfile>

    <!-- ====== PROD Environment ====== -->
    <springProfile name="prod">

        <!-- INFO logs per tenant -->
        <appender name="TENANT_INFO_APPENDER" class="ch.qos.logback.classic.sift.SiftingAppender">
            <discriminator class="ch.qos.logback.classic.sift.MDCBasedDiscriminator">
                <key>tenantId</key>
                <defaultValue>default</defaultValue>
            </discriminator>
            <sift>
                <appender name="INFO-FILE-${tenantId}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                    <file>${LOG_PATH}/${tenantId}/partnerportal_Info.log</file>
                    <filter class="ch.qos.logback.classic.filter.LevelFilter">
                        <level>INFO</level>
                        <onMatch>ACCEPT</onMatch>
                        <onMismatch>DENY</onMismatch>
                    </filter>
                    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                        <fileNamePattern>${LOG_PATH}/${tenantId}/archived/info-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                        <maxFileSize>10MB</maxFileSize>
                        <maxHistory>30</maxHistory>
                    </rollingPolicy>
                    <encoder>
                        <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{tenantId}] - %msg%n</pattern>
                    </encoder>
                </appender>
            </sift>
        </appender>

        <!-- ERROR logs per tenant -->
        <appender name="TENANT_ERROR_APPENDER" class="ch.qos.logback.classic.sift.SiftingAppender">
            <discriminator class="ch.qos.logback.classic.sift.MDCBasedDiscriminator">
                <key>tenantId</key>
                <defaultValue>default</defaultValue>
            </discriminator>
            <sift>
                <appender name="ERROR-FILE-${tenantId}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                    <file>${LOG_PATH}/${tenantId}/partnerportal_Error.log</file>
                    <filter class="ch.qos.logback.classic.filter.LevelFilter">
                        <level>ERROR</level>
                        <onMatch>ACCEPT</onMatch>
                        <onMismatch>DENY</onMismatch>
                    </filter>
                    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                        <fileNamePattern>${LOG_PATH}/${tenantId}/archived/error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                        <maxFileSize>10MB</maxFileSize>
                        <maxHistory>30</maxHistory>
                    </rollingPolicy>
                    <encoder>
                        <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} [%X{tenantId}] - %msg%n</pattern>
                    </encoder>
                </appender>
            </sift>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="TENANT_INFO_APPENDER"/>
            <appender-ref ref="TENANT_ERROR_APPENDER"/>
        </root>
    </springProfile>

</configuration>