# ===== Build Stage =====
FROM maven:3.9.9-eclipse-temurin-21 AS builder
WORKDIR /app

# Copy all source code to /app inside the container
COPY . .

# Build the JAR (skip tests to make it faster)
RUN mvn clean package -Dmaven.test.skip=true

# Base Image
FROM eclipse-temurin:21-jre

LABEL maintainer="Jio Consent Management System <JIOCONSENT@RIL.COM>"

# Create non-root user and standard directories
RUN useradd --create-home --shell /bin/bash si_digigov \
    && mkdir -p /opt/deployment /opt/props /opt/logs \
    && chown -R si_digigov:si_digigov /opt

WORKDIR /opt

# Copy binaries and configs
COPY --from=builder --chown=si_digigov:si_digigov /app/target/*.jar /opt/deployment/
COPY --chown=si_digigov:si_digigov src/main/resources/application.* /opt/props/

# Runtime user
USER si_digigov

# JAVA_OPTS is intentionally left as an override point for ops teams.
ENV JAVA_OPTS=""

# Entrypoint
ENTRYPOINT ["sh", "-c", "exec java $JAVA_OPTS -Dlog_path=/opt/logs -Dspring.config.location=/opt/props/ -jar /opt/deployment/*.jar"]
