package com.jio.digigov.notification.config;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.boot.actuator.health.Health;
import org.springframework.boot.actuator.health.HealthIndicator;
import org.springframework.boot.actuator.info.InfoContributor;
import org.springframework.boot.actuator.info.Info;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.data.mongodb.core.MongoTemplate;
import org.springframework.kafka.core.KafkaTemplate;

import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.HashMap;
import java.util.Map;
import java.util.concurrent.atomic.AtomicLong;

/**
 * Comprehensive health check and metrics configuration for monitoring and observability.
 *
 * This configuration provides detailed health checks for all critical system components
 * including database connectivity, Kafka availability, cache health, and custom business
 * metrics for monitoring application performance and reliability.
 *
 * Health Check Components:
 * - MongoDB connectivity and performance
 * - Kafka producer/consumer health
 * - Cache service availability
 * - External API connectivity (DigiGov)
 * - System resource monitoring
 * - Custom business metrics
 *
 * Metrics Tracking:
 * - Request/response times
 * - Error rates and types
 * - Cache hit/miss ratios
 * - Database query performance
 * - Kafka message throughput
 *
 * @author Notification Service Team
 * @since 1.0.0
 */
// @Configuration
@RequiredArgsConstructor
@Slf4j
public class HealthCheckConfiguration {

    private final MongoTemplate mongoTemplate;
    private final KafkaTemplate<String, Object> kafkaTemplate;

    // Metrics counters
    private final AtomicLong requestCount = new AtomicLong(0);
    private final AtomicLong errorCount = new AtomicLong(0);
    private final AtomicLong cacheHits = new AtomicLong(0);
    private final AtomicLong cacheMisses = new AtomicLong(0);

    /**
     * MongoDB health indicator
     */
    @Bean
    public HealthIndicator mongoHealthIndicator() {
        return () -> {
            try {
                long startTime = System.currentTimeMillis();

                // Test MongoDB connectivity
                mongoTemplate.getCollection("health_check");

                long responseTime = System.currentTimeMillis() - startTime;

                Map<String, Object> details = new HashMap<>();
                details.put("database", "MongoDB");
                details.put("status", "UP");
                details.put("responseTime", responseTime + "ms");
                details.put("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME));

                if (responseTime > 5000) { // Slow response
                    details.put("warning", "Slow database response time");
                    return Health.up().withDetails(details).build();
                }

                return Health.up().withDetails(details).build();

            } catch (Exception e) {
                log.error("MongoDB health check failed: {}", e.getMessage());
                return Health.down()
                        .withDetail("database", "MongoDB")
                        .withDetail("error", e.getMessage())
                        .withDetail("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME))
                        .build();
            }
        };
    }

    /**
     * Kafka health indicator
     */
    @Bean
    public HealthIndicator kafkaHealthIndicator() {
        return () -> {
            try {
                long startTime = System.currentTimeMillis();

                // Test Kafka connectivity by getting metadata
                kafkaTemplate.getProducerFactory().createProducer().partitionsFor("health-check");

                long responseTime = System.currentTimeMillis() - startTime;

                Map<String, Object> details = new HashMap<>();
                details.put("messageQueue", "Kafka");
                details.put("status", "UP");
                details.put("responseTime", responseTime + "ms");
                details.put("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME));

                return Health.up().withDetails(details).build();

            } catch (Exception e) {
                log.error("Kafka health check failed: {}", e.getMessage());
                return Health.down()
                        .withDetail("messageQueue", "Kafka")
                        .withDetail("error", e.getMessage())
                        .withDetail("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME))
                        .build();
            }
        };
    }

    /**
     * Cache health indicator
     */
    @Bean
    public HealthIndicator cacheHealthIndicator() {
        return () -> {
            try {
                Map<String, Object> details = new HashMap<>();
                details.put("component", "Cache Service");
                details.put("status", "UP");
                details.put("totalRequests", requestCount.get());
                details.put("cacheHits", cacheHits.get());
                details.put("cacheMisses", cacheMisses.get());
                details.put("hitRatio", calculateHitRatio());
                details.put("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME));

                return Health.up().withDetails(details).build();

            } catch (Exception e) {
                log.error("Cache health check failed: {}", e.getMessage());
                return Health.down()
                        .withDetail("component", "Cache Service")
                        .withDetail("error", e.getMessage())
                        .withDetail("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME))
                        .build();
            }
        };
    }

    /**
     * Application-specific health indicator
     */
    @Bean
    public HealthIndicator applicationHealthIndicator() {
        return () -> {
            try {
                Map<String, Object> details = new HashMap<>();
                details.put("application", "Notification Producer");
                details.put("version", "1.0.0");
                details.put("status", "UP");
                details.put("uptime", getUptime());
                details.put("totalRequests", requestCount.get());
                details.put("errorCount", errorCount.get());
                details.put("errorRate", calculateErrorRate());
                details.put("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME));

                // Check error rate threshold
                double errorRate = calculateErrorRate();
                if (errorRate > 10.0) { // More than 10% error rate
                    details.put("warning", "High error rate detected");
                }

                return Health.up().withDetails(details).build();

            } catch (Exception e) {
                log.error("Application health check failed: {}", e.getMessage());
                return Health.down()
                        .withDetail("application", "Notification Producer")
                        .withDetail("error", e.getMessage())
                        .withDetail("timestamp", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME))
                        .build();
            }
        };
    }

    /**
     * Custom info contributor for additional application information
     */
    @Bean
    public InfoContributor customInfoContributor() {
        return (Info.Builder builder) -> {
            Map<String, Object> details = new HashMap<>();
            details.put("name", "DPDP Notification Producer");
            details.put("description", "High-performance notification service with Kafka integration");
            details.put("version", "1.0.0");
            details.put("buildTime", LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME));
            details.put("javaVersion", System.getProperty("java.version"));
            details.put("springBootVersion", org.springframework.boot.SpringBootVersion.getVersion());

            // Performance metrics
            Map<String, Object> metrics = new HashMap<>();
            metrics.put("totalRequests", requestCount.get());
            metrics.put("errorCount", errorCount.get());
            metrics.put("errorRate", calculateErrorRate() + "%");
            metrics.put("cacheHitRatio", calculateHitRatio() + "%");
            details.put("metrics", metrics);

            // System information
            Map<String, Object> system = new HashMap<>();
            system.put("processors", Runtime.getRuntime().availableProcessors());
            system.put("maxMemory", formatBytes(Runtime.getRuntime().maxMemory()));
            system.put("totalMemory", formatBytes(Runtime.getRuntime().totalMemory()));
            system.put("freeMemory", formatBytes(Runtime.getRuntime().freeMemory()));
            details.put("system", system);

            builder.withDetail("application", details);
        };
    }

    /**
     * Metrics tracking methods
     */
    public void incrementRequestCount() {
        requestCount.incrementAndGet();
    }

    public void incrementErrorCount() {
        errorCount.incrementAndGet();
    }

    public void incrementCacheHit() {
        cacheHits.incrementAndGet();
    }

    public void incrementCacheMiss() {
        cacheMisses.incrementAndGet();
    }

    private double calculateHitRatio() {
        long total = cacheHits.get() + cacheMisses.get();
        if (total == 0) return 0.0;
        return Math.round((cacheHits.get() * 100.0 / total) * 100.0) / 100.0;
    }

    private double calculateErrorRate() {
        long total = requestCount.get();
        if (total == 0) return 0.0;
        return Math.round((errorCount.get() * 100.0 / total) * 100.0) / 100.0;
    }

    private String getUptime() {
        long uptimeMillis = java.lang.management.ManagementFactory.getRuntimeMXBean().getUptime();
        long hours = uptimeMillis / (1000 * 60 * 60);
        long minutes = (uptimeMillis % (1000 * 60 * 60)) / (1000 * 60);
        return String.format("%d hours, %d minutes", hours, minutes);
    }

    private String formatBytes(long bytes) {
        if (bytes < 1024) return bytes + " B";
        if (bytes < 1024 * 1024) return (bytes / 1024) + " KB";
        if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)) + " MB";
        return (bytes / (1024 * 1024 * 1024)) + " GB";
    }
}